    InputField.TextSize = 14
    InputField.Parent = EntryFrame

    InputField.FocusLost:Connect(rebuildTargetWhitelist)
    table.insert(activeTextBoxes, InputField)
    
    MinusBtn.Visible = (#activeTextBoxes > 1)
    ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, LayoutEngine.AbsoluteContentSize.Y + 40)
end

local function removeLastTextBox()
    if #activeTextBoxes > 1 then
        local targetField = activeTextBoxes[#activeTextBoxes]
        targetField.Parent:Destroy()
        table.remove(activeTextBoxes, #activeTextBoxes)
        MinusBtn.Visible = (#activeTextBoxes > 1)
        rebuildTargetWhitelist()
        ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, LayoutEngine.AbsoluteContentSize.Y)
    end
end

