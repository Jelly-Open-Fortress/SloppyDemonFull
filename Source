-- Fishing script state
local FishingActive = false
local textConnection = nil
local keyConnection = nil
local isUnloaded = false
local originalPosition = nil
local isSpamming = false

-- Helper to safely get the current position of your character
local function getMyPosition()
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	return rootPart and rootPart.Position
end

-- Teleport helper function
local function teleportMe(position)
	if not position then return end
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if rootPart then
		rootPart.CFrame = CFrame.new(position)
	end
end

-- Cleanup function to return you back and fully unload the script
local function unloadFishingScript(reason)
	if isUnloaded then return end
	isUnloaded = true
	isSpamming = false
	FishingActive = false
	
	-- Return to the original position before unloading
	if originalPosition then
		teleportMe(originalPosition)
	end
	
	-- Disconnect listeners to prevent memory leaks
	if textConnection then textConnection:Disconnect() end
	if keyConnection then keyConnection:Disconnect() end
	
	-- Reset button UI
	StartFishBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 70)
	StartFishBtn.Text = "Start Shop Fish"
	StartFishBtn.Active = true
end

-- Key spamming loop function
local function startSpamming(spamInterval)
	isSpamming = true
	
	task.spawn(function()
		while isSpamming and not isUnloaded do
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
			task.wait()
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
			task.wait(spamInterval)
		end
	end)
end

-- Main fishing logic function
local function checkShopText(TARGET_TEXT, STAY_DURATION, SPAM_INTERVAL)
	if isUnloaded then return end
	
	if not originalPosition then
		originalPosition = getMyPosition()
	end
	
	local prompt = workspace:WaitForChild("Interactables")
	                        :WaitForChild("HoboStore")
	                        :WaitForChild("BuyButton")
	                        :WaitForChild("Attachment")
	                        :WaitForChild("Prompt")
	
	-- Teleport Coordinates
	local MATCH_POS = Vector3.new(59, -21, 4)
	local NO_MATCH_POS = Vector3.new(-11, 3, 55)
	
	if prompt.ObjectText == TARGET_TEXT then
		teleportMe(MATCH_POS)
		startSpamming(SPAM_INTERVAL)
		task.wait(STAY_DURATION)
		unloadFishingScript("Completed execution (Target found and timer finished)")
	else
		isSpamming = false
		teleportMe(NO_MATCH_POS)
	end
end

StartFishBtn.MouseButton1Click:Connect(function()
	if FishingActive then return end
	FishingActive = true
	isUnloaded = false
	isSpamming = false
	originalPosition = nil
	
	StartFishBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
	StartFishBtn.Text = "Fishing..."
	StartFishBtn.Active = false
	
	-- Get values from textboxes
	local TARGET_TEXT = TargetTextBox.Text ~= "" and TargetTextBox.Text or "Filament"
	local STAY_DURATION = tonumber(StayDurationBox.Text) or 1
	local SPAM_INTERVAL = tonumber(SpamIntervalBox.Text) or 0.07
	
	-- Listen for changes to ObjectText
	local prompt = workspace:WaitForChild("Interactables")
	                        :WaitForChild("HoboStore")
	                        :WaitForChild("BuyButton")
	                        :WaitForChild("Attachment")
	                        :WaitForChild("Prompt")
	
	textConnection = prompt:GetPropertyChangedSignal("ObjectText"):Connect(function()
		checkShopText(TARGET_TEXT, STAY_DURATION, SPAM_INTERVAL)
	end)
	
	-- Run initial check immediately upon start
	checkShopText(TARGET_TEXT, STAY_DURATION, SPAM_INTERVAL)
end)

-- Abort fishing with N key
local VirtualInputManager = game:GetService("VirtualInputManager")
local UserInputService2 = game:GetService("UserInputService")
UserInputService2.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.N and FishingActive then
		unloadFishingScript("User pressed 'N' key")
	end
end)
