local VirtualInputManager = game:GetService("VirtualInputManager")

local function getMyPosition()
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	return rootPart and rootPart.Position
end

local function teleportMe(position)
	if not position then return end
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if rootPart then rootPart.CFrame = CFrame.new(position) end
end

local function unloadFishingScript(reason)
	if isUnloaded then return end
	isUnloaded = true
	isSpamming = false
	FishingActive = false
	
	if originalPosition then teleportMe(originalPosition) end
	if textConnection then textConnection:Disconnect() end
	
	StartFishBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 70)
	StartFishBtn.Text = "Start Shop Fish"
	StartFishBtn.Active = true
end

local function startSpamming(spamInterval)
	isSpamming = true
	task.spawn(function()
		while isSpamming and not isUnloaded do
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
			task.wait()
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
			task.wait(spamInterval)
		end
	end)
end

-- Updated multi-select evaluation logic for fishing engine
local function checkShopText(STAY_DURATION, SPAM_INTERVAL)
	if isUnloaded then return end
	if not originalPosition then originalPosition = getMyPosition() end
	
	local prompt = workspace:WaitForChild("Interactables")
	                        :WaitForChild("HoboStore")
	                        :WaitForChild("BuyButton")
	                        :WaitForChild("Attachment")
	                        :WaitForChild("Prompt")
	
	local MATCH_POS = Vector3.new(59, -21, 4)
	local NO_MATCH_POS = Vector3.new(-11, 3, 55)
	
	-- Checks if current item matches ANY value configured in multi-select table
	if SELECTED_FISHING_ITEMS[prompt.ObjectText] == true then
		teleportMe(MATCH_POS)
		startSpamming(SPAM_INTERVAL)
		task.wait(STAY_DURATION)
		unloadFishingScript("Completed execution (Target found and timer finished)")
	else
		isSpamming = false
		teleportMe(NO_MATCH_POS)
	end
end

