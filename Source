-- Unlock Recipes state
local UnlockRecipesActive = false
local SavedRecipeStates = {}

UnlockRecipesBtn.MouseButton1Click:Connect(function()
    UnlockRecipesActive = not UnlockRecipesActive
    
    local unlockedItemsFolder = game:GetService("Players").LocalPlayer:FindFirstChild("UnlockedItems")
    
    if not unlockedItemsFolder then
        print("[Unlock Recipes] UnlockedItems folder not found!")
        return
    end
    
    if UnlockRecipesActive then
        -- Save current state
        SavedRecipeStates = {}
        for _, item in ipairs(unlockedItemsFolder:GetChildren()) do
            if item:IsA("BoolValue") then
                SavedRecipeStates[item.Name] = item.Value
            end
        end
        
        -- Unlock all recipes
        for _, item in ipairs(unlockedItemsFolder:GetChildren()) do
            if item:IsA("BoolValue") then
                item.Value = true
            end
        end
        
        UnlockRecipesBtn.BackgroundColor3 = Color3.fromRGB(80, 180, 100)
        UnlockRecipesBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        UnlockRecipesBtn.Text = "ON"
        print("[Unlock Recipes] All recipes unlocked! Saved " .. #SavedRecipeStates .. " items.")
    else
        -- Restore saved state
        for itemName, savedValue in pairs(SavedRecipeStates) do
            local item = unlockedItemsFolder:FindFirstChild(itemName)
            if item and item:IsA("BoolValue") then
                item.Value = savedValue
            end
        end
        
        UnlockRecipesBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
        UnlockRecipesBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        UnlockRecipesBtn.Text = "OFF"
        print("[Unlock Recipes] Recipes restored to previous state.")
        SavedRecipeStates = {}
    end
end)

