-- Weapon Exploitation Engine (Eoka)
task.spawn(function() 
    while true do 
        if EokaAutoKillEnabled then
            local character = LocalPlayer.Character 
            local eoka = character and character:FindFirstChild("Eoka") 
            
            if eoka then 
                local target = getNearestPlayer() 
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then 
                    -- Get the nil remote event for Eoka
                    local function getNil(name, class) 
                        for _, v in next, getnilinstances() do 
                            if v.ClassName == class and v.Name == name then 
                                return v 
                            end 
                        end 
                        return nil
                    end 
                    
                    local eoskaEvent = getNil("Fire", "RemoteEvent")
                    if eoskaEvent then 
                        local targetCFrame = target.Character.HumanoidRootPart.CFrame 
                        local args = { "Fire", targetCFrame } 
                        eoskaEvent:FireServer(unpack(args)) 
                    end 
                end 
            end 
            task.wait(0) 
        else
            task.wait(0.2) 
        end 
    end 
end)

-- Integrated ForceField Spammer Loop
task.spawn(function()
    local areaEvent = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("AreaChangeEvent")
    local args = { "Spawn", false }
    while true do
        if ForceFieldActive then
            areaEvent:FireServer(unpack(args))
            task.wait(0.1) -- Matches your exact delay request
        else
            task.wait(0.3) -- Low-resource sleep mode when toggle is OFF
        end
    end
end)

