-- 1. ENGINE RUNTIME LOGIC (Autokill & ForceField Loops)
-- ============================================================================
local RifleAutoKillEnabled = false 
local DoubleBarrelAutoKillEnabled = false
local EokaAutoKillEnabled = false
local ForceFieldActive = false 
local FRIENDS_LIST = {} 

local Players = game:GetService("Players") 
local Workspace = game:GetService("Workspace") 
local LocalPlayer = Players.LocalPlayer 

local function hasLineOfSight(myPos, targetPos, targetChar) 
    local raycastParams = RaycastParams.new() 
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude 
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, targetChar} 
    raycastParams.IgnoreWater = true 
    local direction = targetPos - myPos 
    local raycastResult = Workspace:Raycast(myPos, direction, raycastParams) 
    return raycastResult == nil 
end 

local function getNearestPlayer() 
    local nearestPlayer = nil 
    local shortestDistance = math.huge 
    local character = LocalPlayer.Character 
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end 
    local myPos = character.HumanoidRootPart.Position 
    
    for _, player in ipairs(Players:GetPlayers()) do 
        if player ~= LocalPlayer and not FRIENDS_LIST[player.Name] then 
            local targetChar = player.Character 
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then 
                local humanoid = targetChar:FindFirstChildOfClass("Humanoid") 
                if humanoid then 
                    local isProtected = targetChar:FindFirstChildOfClass("ForceField") ~= nil 
                    local isAlive = humanoid.Health > 0 and humanoid:GetState() ~= Enum.HumanoidStateType.Dead and targetChar.Parent ~= nil 
                    
                    if isAlive and not isProtected then 
                        local targetPos = targetChar.HumanoidRootPart.Position 
                        local distance = (targetPos - myPos).Magnitude 
                        
                        if distance < shortestDistance then 
                            if hasLineOfSight(myPos, targetPos, targetChar) then 
                                shortestDistance = distance 
                                nearestPlayer = player 
                            end 
                        end 
                    end 
                end 
            end 
        end 
    end 
    return nearestPlayer 
end 

-- Weapon Exploitation Engine (Rifle)
task.spawn(function() 
    while true do 
        if RifleAutoKillEnabled then
            local character = LocalPlayer.Character 
            local rifle = character and character:FindFirstChild("Rifle") 
            local event = rifle and rifle:FindFirstChild("Event") 
            
            if event then 
                local target = getNearestPlayer() 
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then 
                    local targetCFrame = target.Character.HumanoidRootPart.CFrame 
                    local args = { "Fire", targetCFrame } 
                    event:FireServer(unpack(args)) 
                end 
            end 
            task.wait(0) 
        else
            task.wait(0.2) 
        end 
    end 
end)

