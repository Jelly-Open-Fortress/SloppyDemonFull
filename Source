local function switchTab(activeView, activeBtn)
    Page1View.Visible = (activeView == Page1View)
    MeleeView.Visible = (activeView == MeleeView)
    MoneyFarmView.Visible = (activeView == MoneyFarmView)
    MiscView.Visible = (activeView == MiscView)
    
