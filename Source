local lastNotifiedItem = ""
local lastNotifiedTime = 0

local function showNotification(itemName)
    -- Added rate limiting so it won't repeatedly spam notifications if the item stays unchanged
    if itemName == lastNotifiedItem and (os.clock() - lastNotifiedTime) < 5 then return end
    lastNotifiedItem = itemName
    lastNotifiedTime = os.clock()

    ItemNameText.Text = "Item: " .. itemName
    NotificationUI.Visible = true
    
    if SoundIDBox.Text ~= "" then
        local sound = Instance.new("Sound")
        sound.SoundId = SoundIDBox.Text
        sound.Volume = 0.5
        sound.Parent = ScreenGui
        sound:Play()
        game:GetService("Debris"):AddItem(sound, 2)
    end
    
    task.spawn(function()
        task.wait(3)
        if lastNotifiedItem == itemName then
            NotificationUI.Visible = false
        end
    end)
end

